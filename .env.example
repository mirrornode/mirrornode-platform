# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://mirrornode.xyz

# OpenAI (embeddings — text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=sk-...

# Stripe Configuration (Osiris Commerce)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pinecone (Librarian vault)
# Cloud + region must match the index serverless spec
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=mirrornode-vault
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX_DIM=1536

# Supabase / Ledger Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# PTAH / SRIITAG Governance
SRIITAG_JWT_SECRET=your-jwt-secret
SUPABASE_URL=https://your-project-id.supabase.co

# App URL (used in Stripe redirect URLs — local override)
NEXT_PUBLIC_APP_URL=http://localhost:3000
