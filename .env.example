# Copy to .env.local and fill in real values. Never commit .env.local.

# Agent host — FastAPI backend
# Local:      http://localhost:8000
# Production: https://agents.mirrornode.dev (or wherever deployed)
AGENT_BASE_URL=http://localhost:8000

# Strong secret shared between Next.js and FastAPI for Osiris/rotan routes
# Generate: openssl rand -hex 32
ROTAN_DEV_KEY=replace-with-openssl-rand-hex-32

# Supabase project URL (safe to expose to client via NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service-role key — SERVER SIDE ONLY.
# Bypasses row-level security. NEVER prefix with NEXT_PUBLIC_.
# If this leaks into the browser bundle, rotate it immediately in Supabase dashboard.
SUPABASE_SERVICE_KEY=your-service-role-key
