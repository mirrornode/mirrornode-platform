# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://mirrornode.xyz

# Stripe Configuration (Osiris Commerce)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pinecone (Librarian vault)
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=mirrornode-vault

# Supabase / Ledger Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# PTAH / SRIITAG Governance
SRIITAG_JWT_SECRET=your-jwt-secret
# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service-role key — SERVER SIDE ONLY.
# Bypasses row-level security. NEVER prefix with NEXT_PUBLIC_.
# Key name is SUPABASE_SERVICE_ROLE_KEY (not SUPABASE_SERVICE_KEY).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (used in Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
